---
import Section from '../shared/Section.astro';

const testimonials = [
  {
    name: 'C Dan Smith',
    text: 'We contacted Dannstar at 5.15 pm Friday evening - by 1 pm today Saturday she has the iPad back with a new screen & battery fitted - excellent friendly professional service.',
    service: 'iPad Screen & Battery',
    rating: 5,
  },
  {
    name: 'Mick Parkinson',
    text: "Did a great job repairing my phones screen and gave good advice too, fair price, can't complain, would definitely use him again, thanks.",
    service: 'Phone Screen Repair',
    rating: 5,
  },
  {
    name: 'David Gent',
    text: "Very fast and high quality iphone screen replacement, dropped damaged phone off in the morning and ready by lunchtime looking like new. Great communications as well. Couldn't ask for more.",
    service: 'iPhone Screen Repair',
    rating: 5,
  },
];
---

<Section>
  <div class="text-center mb-12 reveal">
    <h2 class="font-(family-name:--font-heading) text-3xl sm:text-4xl font-bold text-(--color-text-primary) mb-4">
      What Our Customers Say
    </h2>
    <p class="text-(--color-text-secondary) text-lg max-w-2xl mx-auto">
      Rated <strong class="text-(--color-text-primary)">4.8 out of 5</strong> from 63 reviews on Google. Here's what real customers think.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {testimonials.map((t, i) => (
      <figure class={`rounded-xl border border-(--color-bg-secondary) bg-(--color-bg-primary) p-6 shadow-sm reveal reveal-delay-${i + 1}`}>
        <!-- Stars -->
        <div class="flex gap-1 mb-3">
          {Array.from({ length: t.rating }).map(() => (
            <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <blockquote class="text-(--color-text-secondary) mb-4 italic">
          <p>"{t.text}"</p>
        </blockquote>
        <figcaption class="flex items-center justify-between">
          <span class="font-semibold text-sm text-(--color-text-primary)">{t.name}</span>
          <span class="text-xs text-(--color-brand) bg-(--color-brand)/10 px-2 py-1 rounded-full">{t.service}</span>
        </figcaption>
      </figure>
    ))}
  </div>

  <div class="text-center mt-8 reveal">
    <a
      href="https://www.google.com/maps/place/DannStarr+Electronics/@52.8147907,-0.1667117,17z/data=!4m8!3m7!1s0x487804ebfcb587a1:0xbd704ccb8f0bede0!8m2!3d52.8147907!4d-0.1667117!9m1!1b1!16s%2Fg%2F12334hp1j"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-(--color-brand) hover:text-(--color-brand-hover) font-semibold transition-colors"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
      </svg>
      See all 63 reviews on Google →
    </a>
  </div>
</Section>
